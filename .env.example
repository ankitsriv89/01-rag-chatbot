# ─── Copy this file to .env and fill in your values ───────────────────────────
# NEVER commit .env to git — it contains secrets.
# .gitignore already excludes .env by default.

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Which LLM to use for generation: "groq" (fast, pay-as-you-go) or "openai"
LLM_PROVIDER=groq

# ─── API Keys ─────────────────────────────────────────────────────────────────
# Groq: https://console.groq.com — pay-as-you-go, very cheap (~$0.59/1M tokens)
GROQ_API_KEY=gsk_your_groq_key_here

# OpenAI: required for embeddings even when using Groq for generation
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ─── Groq Model Selection (with fallback chain) ────────────────────────────────
#
# PRIMARY — best quality, 128k context window
GROQ_MODEL=llama-3.3-70b-versatile
#
# BACKUP OPTIONS (uncomment one if primary hits rate limit or is unavailable):
# GROQ_MODEL=llama-3.1-70b-versatile     # Backup 70B (same quality, different checkpoint)
# GROQ_MODEL=llama3-70b-8192             # Stable alias for 70B, 8k context
# GROQ_MODEL=mixtral-8x7b-32768          # Mixtral MoE — great for long documents (32k ctx)
# GROQ_MODEL=gemma2-9b-it                # Google Gemma 2 — fast, good quality
# GROQ_MODEL=llama-3.1-8b-instant        # Fastest + cheapest — use for dev/testing
# GROQ_MODEL=llama3-8b-8192             # Stable 8B alias — ultra low latency

# Automatic fallback order used when GROQ_MODEL fails (see config.py):
# llama-3.3-70b-versatile → llama-3.1-70b-versatile → mixtral-8x7b-32768 → llama-3.1-8b-instant

# ─── OpenAI Model (used when LLM_PROVIDER=openai) ─────────────────────────────
OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o                    # Best quality (more expensive)
# OPENAI_MODEL=gpt-3.5-turbo            # Cheapest OpenAI option

# ─── Embedding Model ──────────────────────────────────────────────────────────
# Always OpenAI — Groq doesn't offer embedding models
# text-embedding-3-small: 1536 dims, $0.00002/1K tokens (recommended)
# text-embedding-3-large: 3072 dims, $0.00013/1K tokens (better accuracy)
EMBEDDING_MODEL=text-embedding-3-small

# ─── RAG Pipeline Tuning ──────────────────────────────────────────────────────
# Characters per chunk. Larger = more context but higher token cost per query.
CHUNK_SIZE=1000

# Overlap between consecutive chunks. Prevents losing meaning at chunk boundaries.
CHUNK_OVERLAP=200

# How many chunks to retrieve per query (top-k). More = richer context, higher cost.
RETRIEVAL_TOP_K=4

# ─── Vector Store ─────────────────────────────────────────────────────────────
# "faiss" = in-memory (fast, resets on server restart — good for demos)
# "chroma" = persists to disk (survives restarts — good for production)
VECTOR_STORE_TYPE=faiss
CHROMA_PERSIST_DIR=./chroma_db

# ─── App Settings ─────────────────────────────────────────────────────────────
DEBUG=false
MAX_FILE_SIZE_MB=50
MAX_REQUESTS_PER_MINUTE=20

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL the Gradio frontend uses to reach the FastAPI backend.
# Locally: http://localhost:8000
# On HF Spaces: set this as a Space Secret pointing to your deployed backend URL
BACKEND_URL=http://localhost:8000
